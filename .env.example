# Supabase → Project Settings → Database → Connection string
#
# DATABASE_URL: Transaction pooler (port 6543) — used at runtime on Vercel
#   Append ?pgbouncer=true&connection_limit=1 for Prisma compatibility
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: Direct connection (port 5432) — used by prisma db push / migrate
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# Random secret for JWT session cookies (any long random string)
JWT_SECRET="change-this-to-a-long-random-string"

# Secret used to gate the POST /api/seed endpoint (only needed once after deploy)
SEED_SECRET="change-this-too"
