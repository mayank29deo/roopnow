# Postgres connection string (use Neon, Vercel Postgres, Supabase, or local)
# Neon example: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/roopnow?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/roopnow?sslmode=require"

# Random secret for JWT session cookies (any long random string)
JWT_SECRET="change-this-to-a-long-random-string"

# Secret used to gate the POST /api/seed endpoint (only needed once after deploy)
SEED_SECRET="change-this-too"
